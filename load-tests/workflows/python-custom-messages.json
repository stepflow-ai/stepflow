{
  "name": "Load Test - Python Custom Component Messages",
  "description": "Load test workflow using Python custom component for message creation",
  "input_schema": {
    "type": "object",
    "required": ["prompt"],
    "properties": {
      "prompt": {
        "type": "string",
        "description": "The user prompt"
      },
      "system_message": {
        "type": "string",
        "description": "Optional system message to set context",
        "default": "You are a helpful assistant."
      }
    }
  },
  "steps": [
    {
      "id": "create_messages",
      "component": "/custom/create_messages",
      "input": {
        "prompt": {
          "$input": "prompt"
        },
        "system_message": {
          "$input": "system_message"
        }
      }
    }
  ],
  "output": {
    "messages": {
      "$step": "create_messages",
      "path": "messages"
    },
    "message_count": {
      "$step": "create_messages",
      "path": "message_count"
    },
    "total_length": {
      "$step": "create_messages",
      "path": "total_length"
    }
  }
}
