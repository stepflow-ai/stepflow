{
  "name": "Load Test - Python Custom Component OpenAI",
  "description": "Load test workflow using Python custom component to call OpenAI GPT-4o-mini model",
  "input_schema": {
    "type": "object",
    "required": [
      "prompt"
    ],
    "properties": {
      "prompt": {
        "type": "string",
        "description": "The prompt to send to OpenAI"
      },
      "system_message": {
        "type": "string",
        "description": "Optional system message to set context",
        "default": "You are a helpful assistant."
      }
    }
  },
  "steps": [
    {
      "id": "call_openai",
      "component": "/custom/openai_chat",
      "input": {
        "prompt": {
          "$input": "prompt"
        },
        "system_message": {
          "$input": "system_message"
        },
        "max_tokens": 150,
        "temperature": 0.7
      }
    }
  ],
  "output": {
    "response": {
      "$step": "call_openai",
      "path": "response"
    }
  }
}
