# Lightweight runtime image for a pre-built stepflow-server binary.
# Used by docker-compose.ci.yml to avoid the slow multi-stage Rust build.
# Build context: tests/recovery/ (binary must be copied there first)
#
# Uses ubuntu:24.04 to match the CI runner (ubuntu-latest) glibc version.
# debian:bookworm-slim has glibc 2.36 which is too old for binaries built
# on Ubuntu 24.04 (glibc 2.39).

FROM ubuntu:24.04

RUN apt-get update && \
    apt-get install -y ca-certificates libssl3t64 curl && \
    rm -rf /var/lib/apt/lists/*

COPY stepflow-server /usr/local/bin/stepflow-server
RUN chmod +x /usr/local/bin/stepflow-server

RUN useradd -m -u 1000 stepflow
RUN mkdir -p /app/config /app/data && chown -R stepflow:stepflow /app

USER stepflow
WORKDIR /app

EXPOSE 7840

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:7840/api/v1/health || exit 1

CMD ["stepflow-server", "--port", "7840", "--config", "/app/config/stepflow-config.yml"]
