FROM python:3.12-slim

WORKDIR /app

# Install stepflow Python SDK and HTTP deps for the delay-control test API
COPY sdks/python/stepflow-py /build/stepflow-py
RUN pip install --no-cache-dir "/build/stepflow-py" "fastapi>=0.104.1" "uvicorn>=0.24.0"

# Copy the delay component
COPY tests/recovery/components/delay_server.py /app/delay_server.py

# Create tracker directory
RUN mkdir -p /tracker

EXPOSE 8080

# Health check uses the built-in /health endpoint from the SDK HTTP server
HEALTHCHECK --interval=3s --timeout=2s --start-period=5s --retries=10 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8080/health')" || exit 1

CMD ["python", "/app/delay_server.py"]
